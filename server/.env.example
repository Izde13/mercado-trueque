# Base de datos PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=tu_password
DATABASE_NAME=postgres
DATABASE_SCHEMA=mercadotrueque

# URL de conexión completa (usada por Prisma)
DATABASE_URL="postgresql://usuario:password@host:5432/database?schema=mercadotrueque&sslmode=require"

# Puerto del servidor (Render lo asigna automáticamente)
PORT=3000

# JWT Secret (generar uno seguro en producción)
JWT_SECRET=tu_secret_key_aqui

# Entorno
NODE_ENV=development

# ZeroMQ Configuration
# URL de conexión del Publisher de ZMQ (debe coincidir con la del subscriber.py)
ZMQ_URL=tcp://127.0.0.1:5556

# Eventos que se publican a ZMQ (separados por comas)
# Por defecto se publican eventos de Trade importantes para notificaciones por email
ZMQ_PUBLISHABLE_EVENTS=ProposalCreated,ProposalAccepted,ProposalRejected,ProductsShipped,ProductsReviewComplete,ProductsReviewRejected,TradeDelivered,TradeRated,TradeCompleted,TradeCancelled
